# sidekick × ContextOS — the "swap recall + learn" change (2 edits, reversible).
#
# Apply against sidekick/sidekick/orchestrator.py. The whole integration is a drop-in:
# ContextOSSkillStore has the same save/all/recall/record_use surface as SkillStore, so
# the recall site (lines 188-189) and the distill site (line 293) are UNCHANGED.
#
# Toggle with the env var below so it's a safe A/B:
#   SIDEKICK_CONTEXTOS=1   → ContextOS-planned recall + bandit learning
#   unset / =0             → sidekick's original naive token-overlap recall
#
# Apply:  cd sidekick && git apply ../contextos/contextos/integrations/sidekick_orchestrator.patch

--- a/sidekick/orchestrator.py
+++ b/sidekick/orchestrator.py
@@ -23,7 +23,8 @@
 # (imports near the top of the file)
-from .skills import Skill, SkillStore
+from .skills import Skill, SkillStore  # noqa: F401  (Skill still used at the distill site)
+from contextos.integrations.sidekick import make_skill_store, SubtaskOutcome

@@ -184,7 +185,9 @@
-        skills = SkillStore(cfg.skills_dir)
+        # EDIT 1 — swap the store. Same interface; recall() now routes through ContextOS's
+        # planner + retriever + bandit when enabled. use_contextos=False restores the baseline.
+        skills = make_skill_store(cfg.skills_dir, use_contextos=os.environ.get("SIDEKICK_CONTEXTOS") == "1")

         recalled = skills.recall(plan.task)            # UNCHANGED — returns Skills either way
         skill_hint = "\n".join(f"- {s.name}: {s.approach}" for s in recalled)

@@ -285,6 +288,13 @@
             metrics.append(cfg.metrics_path, sub_rec)
             report.objective_records.append(sub_rec)
+            # EDIT 2 — close the loop: feed sidekick's own acceptance/efficiency back so the
+            # bandit learns the recall strategy and the cost-model calibrates. No-op on the
+            # baseline store (guarded by hasattr).
+            if hasattr(skills, "record_outcome"):
+                skills.record_outcome(plan.task, SubtaskOutcome(
+                    accepted=o.accepted, first_attempt=sub_rec.first_attempt,
+                    tokens_total=sub_rec.tokens_total, cost_usd=sub_rec.cost_usd, wall_ms=r.wall_ms,
+                ))

         # Distill a skill from a fully-successful run (Hermes learning loop).
         if mode == "orchestrated" and report.n_accepted == len(plan.subtasks) and plan.subtasks:
